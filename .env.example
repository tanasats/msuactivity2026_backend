PORT=4000
CORS_ORIGIN=http://localhost:3000
FRONTEND_URL=http://localhost:3000

# PostgreSQL — ใช้โดย backend runtime (pg.Pool)
PGHOST=localhost
PGPORT=5432
PGUSER=postgres
PGPASSWORD=postgres
PGDATABASE=msuactivity

# DATABASE_URL — ใช้โดย node-pg-migrate (ถ้าไม่ตั้ง จะ derive จาก PG* ข้างบนอัตโนมัติ)
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/msuactivity

# MinIO (S3-compatible) — เก็บ poster / documents / gallery / selfie
#
# S3_ENDPOINT          = host ที่ backend ใช้คุยกับ MinIO (internal)
#                          - dev บน laptop:        http://localhost:9000
#                          - backend ใน docker:    http://minio:9000  (Docker DNS)
# S3_PUBLIC_ENDPOINT   = host ที่ฝังใน presigned URL ให้ browser เปิด (external)
#                          - dev บน laptop:        ปล่อยว่าง (= S3_ENDPOINT)
#                          - backend ใน docker:    http://localhost:9000  (port mapped)
#                          - production:           https://files.msu.ac.th  (reverse proxy)
#                        ★ ถ้าไม่ตั้ง จะ fallback ไปใช้ S3_ENDPOINT
#                        ★ ตั้งให้ตรงกับสิ่งที่ browser ของผู้ใช้เข้าถึงได้จริง
S3_ENDPOINT=http://localhost:9000
S3_PUBLIC_ENDPOINT=
S3_REGION=us-east-1
S3_BUCKET=msuactivity-files
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_FORCE_PATH_STYLE=true

# Google OAuth (MSU Workspace) — สร้าง credentials ใน Google Cloud Console
# Authorized redirect URI ที่ต้อง add: http://localhost:4000/api/auth/google/callback
GOOGLE_CLIENT_ID=your_client_id_here
GOOGLE_CLIENT_SECRET=your_client_secret_here
GOOGLE_REDIRECT_URI=http://localhost:4000/api/auth/google/callback

# JWT — ห้ามใช้ค่าเริ่มต้นใน production! generate ด้วย: openssl rand -hex 32
JWT_ACCESS_SECRET=dev-access-secret-change-me-in-production-32chars-min
JWT_REFRESH_SECRET=dev-refresh-secret-change-me-in-production-32chars-min
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=30d
